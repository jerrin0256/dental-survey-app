{
  "expo": {
    "name": "Dental Survey App",
    "slug": "dental-survey-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#1A73E8",
      "package": "com.jerryn.dentalsurveyapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A73E8"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b84d57d5-f9ca-4d03-9a6e-ba2647e59e33"
      },
      "apiBaseUrl": "",
      "apiPort": 5001,
      "useProductionApiInDev": false
    },
    "owner": "jerryn"
  }
}
